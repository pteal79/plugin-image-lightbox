{
    "name": "pteal79/plugin-image-lightbox",
    "description": "A NativePHP plugin that displays images in a full-screen native lightbox with zoom, pan, and share support.",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Peter Teal",
            "email": "info@middevondigital.co.uk"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nativephp\\ImageLightbox\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nativephp\\ImageLightbox\\ImageLightboxServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
