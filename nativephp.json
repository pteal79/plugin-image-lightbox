{
    "namespace": "ImageLightbox",

    "bridge_functions": [
        {
            "name": "ImageLightbox.Show",
            "android": "com.nativephp.plugins.imagelightbox.ImageLightboxFunctions.Show",
            "ios": "ImageLightboxFunctions.Show",
            "description": "Display an image in a full-screen native lightbox overlay"
        }
    ],

    "android": {
        "permissions": [
            "android.permission.INTERNET"
        ],
        "dependencies": {
            "implementation": []
        },
        "activities": [],
        "services": [],
        "receivers": [],
        "providers": []
    },

    "ios": {
        "info_plist": {},
        "dependencies": {
            "swift_packages": [],
            "pods": []
        }
    },

    "events": [
        "Pteal79\\ImageLightbox\\Events\\EditPressed",
        "Pteal79\\ImageLightbox\\Events\\MarkupPressed",
        "Pteal79\\ImageLightbox\\Events\\DeletePressed",
        "Pteal79\\ImageLightbox\\Events\\ClosePressed"
    ],

    "hooks": {
        "copy_assets": "nativephp:image-lightbox:copy-assets"
    }
}
